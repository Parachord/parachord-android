<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  MusicKit capability — required for ApplicationMusicPlayer catalog
	  playback (Apple Music). With CODE_SIGN_STYLE = Automatic + a real
	  DEVELOPMENT_TEAM, Xcode provisions this against the App ID when
	  building to a device. The iTunes-Search resolve path needs no auth,
	  but PLAYING a resolved Apple Music track needs this + an Apple Music
	  subscription on a real device.
	-->
	<key>com.apple.developer.musickit</key>
	<true/>
</dict>
</plist>
